{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently --names \"server,client\" --prefix-colors \"cyan,magenta\" \"pnpm --filter @workspace/api-server dev\" \"pnpm --filter @workspace/skribbl dev\"",
    "build": "pnpm --filter @workspace/skribbl build && pnpm --filter @workspace/api-server build",
    "start": "pnpm --filter @workspace/api-server start",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
